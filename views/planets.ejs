<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/styles/main.css">
    <title>DBZ Planets</title>
</head>

<body>

    <img src="/styles/Dragon-Ball-Z-Logo-PNG-File.png" class="logo2" alt="DBZ Logo">


    <div class="nav-container">
        <a href="/" class="back-to-homepage">Back to Home</a>
    </div>


    <form action="/search-planets" method="GET" class="search-form">
        <input type="text" name="name" placeholder="Search Planet (e.g. Namek)" class="search-bar">
        <button type="submit" class="submit-button">Search</button>
    </form>



    <div class="grid-container">
        <% if (planets.length> 0) { %>

            <% planets.forEach(planet=> { %>
                <div class="card card-2 card-hidden">
                    <img src="<%= planet.image %>" alt="<%= planet.name %>" style="width:100%">

                    <h2>
                        <%= planet.name %>
                    </h2>

                    <hr>

                    <p class="description-planet">
                        <%= planet.description %>
                    </p>

                    <p class="destroyed">
                        Destroyed: <%= planet.isDestroyed ? "Yes" : "No" %>
                    </p>
                </div>
                <% }) %>

                    <% } else { %>
                        <p class="no-results">No planets found.</p>
                        <% } %>
    </div>



    <div class="pagination">
        <% if (currentPage> 1) { %>
            <a href="/planets?page=<%= currentPage - 1 %>" class="prev-next prev">Previous</a>
            <% } %>

                <span class="page-indicator">Page <%= currentPage %></span>

                <% if (currentPage < totalPages) { %>
                    <a href="/planets?page=<%= currentPage + 1 %>" class="prev-next next">Next</a>
                    <% } %>
    </div>



    <button id="mute-btn" class="mute-button">
        <span id="mute-icon">🔊</span>
    </button>



    <script>
        // Intersection Observer for planet cards entry animation
        const observer = new IntersectionObserver((entries) => {
            entries.forEach((entry) => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('card-show');
                }
            });
        }, {
            threshold: 0.1
        });

        const hiddenElements = document.querySelectorAll('.card-hidden');
        hiddenElements.forEach((el) => observer.observe(el));
    </script>


    <script src="/audio-handler.js"></script>

</body>

</html>