<!DOCTYPE html>
<html lang="en">

<head>
    <link rel="stylesheet" href="/styles/main.css">
    <title>DBZ Planets</title>
</head>

<body>
    <h1>Planets</h1>
    <img src="/styles/Dragon-Ball-Z-Logo-PNG-File.png" class="logo2" alt="DBZ Logo">

    <a href="/" style="color: #ff9800;">Back to Home</a>

    <form action="/search-characters" method="GET" class="search-form">
        <input type="text" name="name" placeholder="Search Saiyans, Androids..."
            value="<%= typeof searchName !== 'undefined' ? searchName : '' %>">
        <button type="submit">Search</button>
    </form>

    <div class="grid-container">
        <% if (characters.length> 0) { %>
            <% characters.forEach(character=> { %>
                <div class="card">
                    <img  class="new" src="<%= character.image %>" alt="<%= character.name %>" style="width:100%">
                    <h3>
                        <%= character.name %>
                    </h3>
                    <h3>KI:<%= character.ki %></h3>
                    <p>Destroyed: <%= character.isDestroyed ? "Yes" : "No" %>
                    </p>
                </div>
                <% }) %>
                    <% } else { %>
                        <p>No planets found.</p>
                        <% } %>
    </div>



    <div class="pagination">
        <% if (currentPage> 1) { %>
            <a href="/characters?page=<%= currentPage - 1 %>">Previous</a>
            <% } %>
                <span>Page <%= currentPage %></span>
                <a href="/characters?page=<%= currentPage + 1 %>">Next</a>
    </div>
</body>

</html>